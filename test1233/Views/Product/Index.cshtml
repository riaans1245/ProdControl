@model test1233.Models.PagedListViewModel<test1233.Models.AppProduct>

@{
    ViewData["Title"] = "Products";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Product Management</h1>
            <p class="text-muted mb-0">Manage products and link each one to a category.</p>
        </div>
        <a asp-action="Create" class="btn text-white" style="background-color: #080808; color: #123246;">Add product</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Product</th>
                            <th>Price</th>
                            <th>Category</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var product in Model.Items)
                    {
                        <tr>
                            <td>@product.Id</td>
                            <td>@product.Name</td>
                            <td>@product.Price.ToString("C")</td>
                            <td>@product.CategoryName</td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-4">
                <span class="text-muted small">Page @Model.PageNumber of @Model.TotalPages</span>
                <nav aria-label="Product pagination">
                    <ul class="pagination mb-0">
                        <li class="page-item @(Model.HasPreviousPage ? string.Empty : "disabled")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageNumber - 1)">Previous</a>
                        </li>
                        @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
                        {
                            <li class="page-item @(pageNumber == Model.PageNumber ? "active" : string.Empty)">
                                <a class="page-link" asp-action="Index" asp-route-page="@pageNumber">@pageNumber</a>
                            </li>
                        }
                        <li class="page-item @(Model.HasNextPage ? string.Empty : "disabled")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageNumber + 1)">Next</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>
