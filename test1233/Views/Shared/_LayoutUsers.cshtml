@inject test1233.Services.IUserStore UserStore

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Easy Eats</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/test1233.styles.css" asp-append-version="true" />
    <script>
        (() => {
            if (sessionStorage.getItem("left-nav-collapsed") === "true" || sessionStorage.getItem("left-nav-hidden") === "true") {
                document.documentElement.classList.add("left-nav-collapsed-state");
            }
        })();
    </script>
    <style>
        .left-nav-toggle-btn {
            border: 1px solid #737575;
            background-color: transparent;
        }

        .left-nav-toggle-btn:focus,
        .left-nav-toggle-btn:active {
            box-shadow: none;
            outline: none;
        }
    </style>
</head>
<body class="user-shell d-flex flex-column min-vh-100 m-0">
    @{
        var isUser = User.IsInRole("Users");
        var currentUsername = User.Identity?.Name;
        var currentUserId = UserStore
            .GetAllUsers()
            .FirstOrDefault(user => string.Equals(user.Username, currentUsername, StringComparison.OrdinalIgnoreCase))
            ?.Id;
    }
    <!-- Top Navigation Bar --> 
    <nav class="navbar navbar-expand-md navbar-dark border-bottom shadow-sm py-3 user-topbar"> 
        <div class="container-fluid"> 
           
                <button id="left-nav-toggle"
                        type="button"
                        class="navbar-toggler me-3 d-inline-flex left-nav-toggle-btn"
                        aria-label="Toggle left navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
            
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">Easy Eats</a> 
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation"> 
                <span class="navbar-toggler-icon">

                </span> 
            </button> 
        <div class="navbar-collapse collapse d-md-inline-flex justify-content-between"> 
            <!-- Topbar Left Menu Links --> 
            <ul class="navbar-nav flex-grow-1 align-items-md-center"> 
                <li class="nav-item"> 
                    <a class="nav-link text-white px-3" asp-controller="Home" asp-action="Index">Home</a> 
                </li> 
              @*   <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle text-white px-3"
                       href="#"
                       id="reportsDropdown"
                       role="button"
                       data-bs-toggle="dropdown"
                       data-bs-offset="0,18"
                       aria-expanded="false">
                        Reports
                    </a>
                    <ul class="dropdown-menu reports-dropdown-menu" aria-labelledby="reportsDropdown" style="width: 5px;">
                        <li>
                            <a class="dropdown-item reports-dropdown-item" style="background-color: #fff4db; color: #214049;" asp-controller="Reports" asp-action="Roles" target="_blank" rel="noopener noreferrer">
                                <span class="reports-dropdown-title">My Purchase Report</span>
                                <span class="reports-dropdown-description">Purchases in a timeframe ...</span>
                            </a>
                        </li>
                    <li>
                            <a class="dropdown-item reports-dropdown-item" style="background-color: #fff4db; color: #214049;" asp-controller="Reports" asp-action="Roles" target="_blank" rel="noopener noreferrer">
                                <span class="reports-dropdown-title">My Token Report</span>
                                <span class="reports-dropdown-description">When I userd my Tokens ...</span>
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item reports-dropdown-item" style="background-color: #fff4db; color: #214049;" asp-controller="Reports" asp-action="Roles" target="_blank" rel="noopener noreferrer">
                                <span class="reports-dropdown-title">My Login Report</span>
                                <span class="reports-dropdown-description">Time and date when I Logged in ...</span>
                            </a>
                        </li>
                    </ul>
                </li> *@
            
                @if (User.Identity?.IsAuthenticated == true)
                {
                <a asp-controller="Home" asp-action="Ordering" class="nav-link text-white px-3">Start ordering</a>
                }
                
            </ul> 
            <!-- Topbar Right Authentication Controls --> 
            <ul class="navbar-nav align-items-center gap-2"> 
                @if (User.Identity?.IsAuthenticated == true) 
                { 
                    <li class="nav-item">
                        <a class="nav-link text-white px-3 nav-cart-link" asp-controller="Home" asp-action="Ordering" aria-label="View cart">
                            <span class="nav-cart-icon-wrapper">
                                <span class="nav-cart-image" aria-hidden="true"></span>
                                <span id="nav-cart-count" class="nav-cart-count-badge">0</span>
                            </span>
                        </a>
                    </li>
                    <li class="nav-item"> 
                        <span></span>
                        <label name=lblUserInfo class="fw-semibold me-2">Welcome, @User.Identity.Name!</label>
                    </li> 
                    <li class="nav-item"> 
                        <form class="m-0" asp-controller="Account" asp-action="Logout" method="post"> 
                            @Html.AntiForgeryToken() 
                            <button type="submit" class="btn px-3 fw-semibold" style="background-color: #fff4db; color: #214049;">Logout</button> 
                        </form> 
                    </li> 
                    } 
                    else 
                    { 
                        <li class="nav-item"> 
                            <a class="nav-link text-white px-3" asp-controller="Account" asp-action="Register">Register</a> 
                            </li> 
                        <li class="nav-item"> 
                            <a class="nav-link text-white px-3" asp-controller="Account" asp-action="Login">Login</a> 
                        </li> 
                    } 
                    </ul> 
                </div> 
            </div> 
        </nav> 
    <!-- Main Workspace Container --> 
    <div class="d-flex flex-grow-1 align-items-stretch app-shell"> 
        <!-- Side Navigation Bar (Stretches from navbar to footer via min-vh-100) --> 
        @if (User.Identity?.Name == null || isUser)
        {
        <div class="flex-shrink-0 app-sidebar" id="left-navigation">
            <nav class="p-4 shadow-sm h-100 user-sidebar-nav"> 
                <div class="border rounded-4 p-3 mb-4 sidebar-heading-card user-sidebar-card">
                    <p class="mb-2 user-sidebar-kicker">My Space</p>
                    <p class="mb-1 fw-semibold user-sidebar-title">Welcome</p>
                    <p class="mb-0 user-sidebar-copy">Jump between ordering, profile details, tokens, and updates.</p>
                </div>
                <div class="user-floating-stack">
                    <div class="border rounded-4 p-3 mb-4 sidebar-heading-card user-sidebar-card">
                        <span class="user-floating-label">Available Tokens</span>
                        <!--<span class="user-floating-value">@(currentUsername ?? "Guest")</span>-->
                        <span class="user-floating-value">123456789</span>
                    </div>
                </div>
                <ul class="nav nav-pills flex-column gap-2"> 
                    <div class="left-nav-gallery-panel">
                        <a class="left-nav-gallery-card left-nav-gallery-card-menu"
                            asp-controller="Home"
                            title="Menu"
                            asp-action="Ordering">
                                <span class="left-nav-gallery-icon" aria-hidden="true"></span>
                                <span class="left-nav-gallery-label">Our Menu</span>
                        </a>
                    <hr />
                        <a class="left-nav-gallery-card left-nav-gallery-card-users"
                            asp-controller="User"
                            asp-route-id="@currentUserId"
                            asp-action="Edit"
                            title="My Profile"
                            aria-label="My Profile">
                                <span class="left-nav-gallery-icon" aria-hidden="true"></span>
                                <span class="left-nav-gallery-label">My Profile</span>
                        </a>
                        <a class="left-nav-gallery-card left-nav-gallery-card-tokens"
                                asp-controller="User"
                                asp-route-id="@currentUserId"
                                asp-action="Edit"
                                title="My Tokens"
                                aria-label="My Tokens">
                                    <span class="left-nav-gallery-icon" aria-hidden="true"></span>
                                    <span class="left-nav-gallery-label">My Tokens</span>
                        </a>
                        <a class="left-nav-gallery-card left-nav-gallery-card-notifications"
                            asp-controller="Home"
                            title="My Notifications"
                            asp-action="Specials">
                                <span class="left-nav-gallery-icon" aria-hidden="true"></span>
                                <span class="left-nav-gallery-label">My Notifications</span>
                        </a>
                        <a class="left-nav-gallery-card left-nav-gallery-card-notifications"
                            asp-controller="Home"
                            title="My Notifications"
                            asp-action="Specials">
                                <span class="left-nav-gallery-icon" aria-hidden="true"></span>
                                <span class="left-nav-gallery-label">My Purchases</span>
                        </a>
                    </div>
                </ul> 
            </nav>
        </div> 
        }

        <!-- Dynamic Main View Content Area --> 
        <main role="main" class="flex-grow-1 p-0 overflow-auto"> 
            <div class="user-content-surface">
                <section class="user-content-hero">
                    <div>
                        <p class="user-content-kicker">Customer Area</p>
                        <h1 class="h4 user-content-title">Easy Eats user dashboard</h1>
                        <p class="user-content-copy">Kitchen note: good food takes time, but quick links help.</p>
                        <p class="user-kitchen-note mb-0"><strong>Fresh from the kitchen:</strong> your menu, profile, and updates are all close at hand.</p>
                    </div>
                </section>
                @RenderBody()
            </div>
        </main> 
    </div> 
    <!-- Footer Area --> 
    <footer class="footer border-top mt-auto shadow-sm user-footer" style="height: 55px;"> 
        <div class="container-fluid d-flex justify-content-between align-items-center h-100 px-4"> 
            <a class="nav-link text-white px-3" asp-controller="Home" asp-action="ContactUs">Contact Us</a> 
            <ul class="nav"> 
                <li class="nav-item"> 
                    <span class="nav-link text-white px-3">Created by Riaan</span> 
                </li> 
            </ul> 
        </div> 
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (() => {
            const leftNavigation = document.getElementById("left-navigation");
            const leftNavToggle = document.getElementById("left-nav-toggle");

            if (!leftNavigation || !leftNavToggle) {
                return;
            }

            const syncButtonState = () => {
                const isExpanded = !leftNavigation.classList.contains("app-sidebar-collapsed");
                leftNavToggle.setAttribute("aria-expanded", isExpanded ? "true" : "false");
                leftNavToggle.setAttribute("title", isExpanded ? "Hide Menu" : "Show Menu");
            };

            leftNavToggle.addEventListener("click", () => {
                leftNavigation.classList.toggle("app-sidebar-collapsed");
                const isCollapsed = leftNavigation.classList.contains("app-sidebar-collapsed");
                sessionStorage.setItem("left-nav-collapsed", isCollapsed ? "true" : "false");
                sessionStorage.removeItem("left-nav-hidden");
                document.documentElement.classList.toggle("left-nav-collapsed-state", isCollapsed);
                syncButtonState();
            });

            if (sessionStorage.getItem("left-nav-collapsed") === "true" || sessionStorage.getItem("left-nav-hidden") === "true") {
                leftNavigation.classList.add("app-sidebar-collapsed");
            }

            syncButtonState();
        })();

    </script>
    <script>
        (() => {
            const cartStorageKey = "easy-eats-cart";
            const cartCount = document.getElementById("nav-cart-count");

            if (!cartCount) {
                return;
            }

            const readCart = () => {
                try {
                    const rawCart = localStorage.getItem(cartStorageKey);
                    const parsedCart = rawCart ? JSON.parse(rawCart) : [];
                    return Array.isArray(parsedCart) ? parsedCart : [];
                } catch {
                    return [];
                }
            };

            const syncCartSummary = () => {
                const cart = readCart();
                const totalItems = cart.reduce((sum, item) => sum + (Number(item.quantity) || 0), 0);

                cartCount.textContent = totalItems.toString();
            };

            window.addEventListener("storage", syncCartSummary);
            window.addEventListener("cart-updated", syncCartSummary);
            syncCartSummary();
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
