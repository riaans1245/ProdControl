@model IReadOnlyCollection<test1233.Models.AppCategory>

@{
    ViewData["Title"] = "Category Report";
    Layout = "~/Views/Shared/_ReportLayout.cshtml";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Category Report</h1>
            <p class="text-muted mb-0">Current categories available in the system.</p>
        </div>
        <a asp-action="ExportCategories" class="btn btn-success">Export to Excel</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Name</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var category in Model)
                    {
                        <tr>
                            <td>@category.Id</td>
                            <td>@category.Name</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
