@model test1233.Models.AppTokens

@{
    ViewData["Title"] = "Delete Token";
}

<div class="container py-4" style="max-width: 620px;">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <h1 class="h3 mb-3">Delete Token</h1>
            <p class="text-muted">Are you sure you want to delete this token?</p>

            <dl class="row mb-4">
                <dt class="col-sm-3">Token</dt>
                <dd class="col-sm-9">@Model.Token</dd>

                <dt class="col-sm-3">User</dt>
                <dd class="col-sm-9">@Model.Username</dd>
            </dl>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="TokenId" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">Delete</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
