<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Easy Eats</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/test1233.styles.css" asp-append-version="true" />
    <style>
        .app-shell {
            min-height: 0;
        }
    </style>
</head>
<body class="admin-shell d-flex flex-column min-vh-100 m-0">
    @{
        var isAdmin = User.IsInRole("Admin");
    }
    <!-- Top Navigation Bar --> 
    <nav class="navbar navbar-expand-md navbar-dark border-bottom shadow-sm py-3 admin-topbar"> 
        <div class="container-fluid"> 
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">Easy Eats Admin</a> 
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation"> 
                <span class="navbar-toggler-icon">

                </span> 
            </button> 
        <div class="navbar-collapse collapse d-md-inline-flex justify-content-end"> 
            <!-- Topbar Right Authentication Controls --> 
            <ul class="navbar-nav align-items-center gap-2"> 
                @if (User.Identity?.IsAuthenticated == true) 
                { 
                    <li class="nav-item"> 
                        <label name=lblUserInfo class="fw-semibold me-2">Welcome, @User.Identity.Name!</label>
                    </li> 
                    <li class="nav-item"> 
                        <form class="m-0" asp-controller="Account" asp-action="Logout" method="post"> 
                            @Html.AntiForgeryToken() 
                            <button type="submit" class="btn px-3 fw-semibold" style="background-color: #d0eef7; color: #123246;">Logout</button> 
                        </form> 
                    </li> 
                    } 
                    else 
                    { 
                        <li class="nav-item"> 
                            <a class="nav-link text-white px-3" asp-controller="Account" asp-action="Register">Register</a> 
                            </li> 
                        <li class="nav-item"> 
                            <a class="nav-link text-white px-3" asp-controller="Account" asp-action="Login">Login</a> 
                        </li> 
                    } 
                    </ul> 
                </div> 
            </div> 
        </nav> 
    <!-- Main Workspace Container --> 
    <div class="d-flex flex-grow-1 align-items-stretch app-shell"> 
        @if (isAdmin)
        {
            <aside class="flex-shrink-0 app-sidebar">
                <nav class="p-4 shadow-sm h-100 admin-sidebar-nav">
                    <div class="admin-sidebar-scroll">
                        <div class="border rounded-4 p-3 mb-4 sidebar-heading-card admin-sidebar-card">
                            <p class="mb-2 admin-sidebar-kicker">Navigation</p>
                            <p class="mb-1 fw-semibold admin-sidebar-title">Admin menu</p>
                            <p class="mb-0 admin-sidebar-copy">Move through pages and reports without crowding the top bar.</p>
                        </div>
                        <div class="left-nav-gallery-panel">
                            <a class="left-nav-gallery-card left-nav-gallery-card-menu" asp-controller="Home" asp-action="Index">
                                <span class="left-nav-gallery-icon" aria-hidden="true"></span>
                                <span class="left-nav-gallery-label">Home</span>
                            </a>
                            <a class="left-nav-gallery-card left-nav-gallery-card-users" asp-controller="Home" asp-action="Private">
                                <span class="left-nav-gallery-icon" aria-hidden="true"></span>
                                <span class="left-nav-gallery-label">Registered Users</span>
                            </a>
                            <a class="left-nav-gallery-card left-nav-gallery-card-users" asp-controller="User" asp-action="Index">
                                <span class="left-nav-gallery-icon" aria-hidden="true"></span>
                                <span class="left-nav-gallery-label">Users</span>
                            </a>
                            <a class="left-nav-gallery-card left-nav-gallery-card-roles" asp-controller="Role" asp-action="Index">
                                <span class="left-nav-gallery-icon" aria-hidden="true"></span>
                                <span class="left-nav-gallery-label">Roles</span>
                            </a>
                            <a class="left-nav-gallery-card left-nav-gallery-card-products" asp-controller="Product" asp-action="Index">
                                <span class="left-nav-gallery-icon" aria-hidden="true"></span>
                                <span class="left-nav-gallery-label">Products</span>
                            </a>
                            <a class="left-nav-gallery-card left-nav-gallery-card-categories" asp-controller="Category" asp-action="Index">
                                <span class="left-nav-gallery-icon" aria-hidden="true"></span>
                                <span class="left-nav-gallery-label">Categories</span>
                            </a>
                            <a class="left-nav-gallery-card left-nav-gallery-card-menu" asp-controller="Home" asp-action="Ordering">
                                <span class="left-nav-gallery-icon" aria-hidden="true"></span>
                                <span class="left-nav-gallery-label">Our Menu</span>
                            </a>
                            <a class="left-nav-gallery-card left-nav-gallery-card-notifications" asp-controller="Home" asp-action="Specials">
                                <span class="left-nav-gallery-icon" aria-hidden="true"></span>
                                <span class="left-nav-gallery-label">Notifications</span>
                            </a>
                            <a class="left-nav-gallery-card left-nav-gallery-card-tokens" asp-controller="Home" asp-action="Tokens">
                                <span class="left-nav-gallery-icon" aria-hidden="true"></span>
                                <span class="left-nav-gallery-label">Tokens</span>
                            </a>
                        </div>
                    </div>
                    <hr class="admin-nav-divider" />
                    <div class="left-nav-gallery-panel">
                        <a class="left-nav-gallery-card left-nav-gallery-card-roles" asp-controller="Reports" asp-action="Index">
                            <span class="left-nav-gallery-icon" aria-hidden="true"></span>
                            <span class="left-nav-gallery-label">Report</span>
                        </a>
                    </div>
                </nav>
            </aside>
        }
        <!-- Dynamic Main View Content Area --> 
        <main role="main" class="flex-grow-1 p-0 overflow-auto admin-content"> 
            <div class="admin-content-surface">
                @RenderBody()
            </div>
        </main> 
    </div> 
    <!-- Footer Area --> 
    <footer class="footer border-top mt-auto shadow-sm admin-footer" style="height: 55px;"> 
        <div class="container-fluid d-flex justify-content-between align-items-center h-100 px-4"> 
            <ul class="nav"> 
                <li class="nav-item"> 
                    <span class="nav-link text-white px-3">Created by Riaan</span> 
                </li> 
            </ul> 
        </div> 
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (() => {
            const cartStorageKey = "easy-eats-cart";
            const cartCount = document.getElementById("nav-cart-count");

            if (!cartCount) {
                return;
            }

            const readCart = () => {
                try {
                    const rawCart = localStorage.getItem(cartStorageKey);
                    const parsedCart = rawCart ? JSON.parse(rawCart) : [];
                    return Array.isArray(parsedCart) ? parsedCart : [];
                } catch {
                    return [];
                }
            };

            const syncCartSummary = () => {
                const cart = readCart();
                const totalItems = cart.reduce((sum, item) => sum + (Number(item.quantity) || 0), 0);

                cartCount.textContent = totalItems.toString();
            };

            window.addEventListener("storage", syncCartSummary);
            window.addEventListener("cart-updated", syncCartSummary);
            syncCartSummary();
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
