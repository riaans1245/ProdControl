@model test1233.Models.TokenFormViewModel

@{
    ViewData["Title"] = "Create Token";
}

<div class="container py-4" style="max-width: 620px;">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <h1 class="h3 mb-3">Create Token</h1>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Token" class="form-label"></label>
                    <input asp-for="Token" class="form-control" />
                    <span asp-validation-for="Token" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="UserId" class="form-label"></label>
                    <select asp-for="UserId" asp-items="Model.AvailableUsers" class="form-select"></select>
                    <span asp-validation-for="UserId" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-dark">Save</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
