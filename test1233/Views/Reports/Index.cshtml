@{
    ViewData["Title"] = "Reports";
}

<div class="container py-4">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <h1 class="h3 mb-3">Reports</h1>
            <p class="text-muted mb-4">Choose a report from the list below to open it on its own page.</p>

            <div class="d-flex flex-column gap-2">
                <a asp-action="Roles" class="btn btn-outline-dark text-start" target="_blank" rel="noopener noreferrer">Role Report</a>
                <a asp-action="Users" class="btn btn-outline-dark text-start" target="_blank" rel="noopener noreferrer">User Report</a>
                <a asp-action="Products" class="btn btn-outline-dark text-start" target="_blank" rel="noopener noreferrer">Product Report</a>
                <a asp-action="Categories" class="btn btn-outline-dark text-start" target="_blank" rel="noopener noreferrer">Category Report</a>
                <a asp-action="ContactUs" class="btn btn-outline-dark text-start" target="_blank" rel="noopener noreferrer">Contact Us Report</a>
            </div>
        </div>
    </div>
</div>
