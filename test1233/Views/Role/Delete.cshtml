@model test1233.Models.AppRole

@{
    ViewData["Title"] = "Delete Role";
    var userCount = ViewData["UserCount"] as int? ?? 0;
}

<div class="container py-4" style="max-width: 620px;">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <h1 class="h3 mb-3">Delete Role</h1>
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <p class="mb-2">You are deleting <strong>@Model.Id - @Model.Name</strong>.</p>
            <p class="text-muted">Assigned users: @userCount</p>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">Delete</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
