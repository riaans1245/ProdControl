@model test1233.Models.RoleIndexViewModel

@{
    ViewData["Title"] = "Roles";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Role Management</h1>
            <p class="text-muted mb-0">Seeded roles include 1 - Admin and 2 - Users.</p>
        </div>
        <a asp-action="Create" class="btn text-white" style="background-color: #080808; color: #123246;">Add role</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Name</th>
                            <th>Code</th>
                            <th>Users</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var role in Model.Roles)
                    {
                        <tr>
                            <td>@role.Id</td>
                            <td>@role.Name</td>
                            <td>@role.IdentityCode</td>
                            <td>@Model.UserCountsByRoleId.GetValueOrDefault(role.Id)</td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@role.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@role.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
