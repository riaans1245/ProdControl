@model IReadOnlyCollection<test1233.Models.AppTokens>

@{
    ViewData["Title"] = "Tokens";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Token Management</h1>
            <p class="text-muted mb-0">Manage tokens and link each one to a user.</p>
        </div>
        <a asp-action="Create" class="btn text-white" style="background-color: #080808; color: #123246;">Add token</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>TokenId</th>
                            <th>Token</th>
                            <th>User</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var tokens in Model)
                    {
                        <tr>
                            <td>@tokens.TokenId</td>
                            <td>@tokens.Token</td>
                            <td>@tokens.Username</td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@tokens.TokenId" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@tokens.TokenId" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>
