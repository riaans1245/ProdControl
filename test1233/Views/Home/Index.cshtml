@{
    ViewData["Title"] = "Home Page";
    var isAdmin = User.IsInRole("Admin");
    var isNotAdmin = User.IsInRole("Users");
       
}

<div class="container py-4">
    @if (TempData["MagicLinkEmail"] is string magicLinkEmail && TempData["MagicLinkUrl"] is string magicLinkUrl)
    {
        <div class="alert alert-info shadow-sm" role="alert">
            <strong>Magic link prepared for @magicLinkEmail</strong><br />
            <a href="@magicLinkUrl">@magicLinkUrl</a>
        </div>
    }
    @if (isAdmin)
    {
        <section class="admin-blocks-panel">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
                <div>
                    <p class="text-uppercase fw-semibold text-muted mb-2" style="letter-spacing: 0.12em;">Admin dashboard</p>
                    <h1 class="h3 mb-1">Manage Easy Eats from one screen</h1>
                    <p class="text-muted mb-0">Quick access to users, products, reports, and customer-facing pages.</p>
                </div>
            </div>
        </section>
    }
</div>
