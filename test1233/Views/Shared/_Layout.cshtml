<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Easy Eats</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/test1233.styles.css" asp-append-version="true" />
    <style>
        .app-shell {
            min-height: 0;
        }
    </style>
</head>
<body class="admin-shell d-flex flex-column min-vh-100 m-0">
    @{
        var isAdmin = User.IsInRole("Admin");
        var isUser = User.IsInRole("Users");
    }
    <!-- Top Navigation Bar --> 
    <nav class="navbar navbar-expand-md navbar-dark border-bottom shadow-sm py-3 admin-topbar"> 
        <div class="container-fluid"> 
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">Easy Eats Admin</a> 
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation"> 
                <span class="navbar-toggler-icon">

                </span> 
            </button> 
        <div class="navbar-collapse collapse d-md-inline-flex justify-content-between"> 
            <!-- Topbar Left Menu Links --> 
            <ul class="navbar-nav flex-grow-1 align-items-md-center"> 
                <li class="nav-item"> 
                        <a class="nav-link text-white px-3" asp-controller="Home" asp-action="Index">Home</a> 
                    </li> <li class="nav-item"> 
                        <a class="nav-link text-white px-3" asp-controller="Home" asp-action="Private">Registered Users</a> 
                    </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle text-white px-3"
                       href="#"
                       id="reportsDropdown"
                       role="button"
                       data-bs-toggle="dropdown"
                       data-bs-offset="0,18"
                       aria-expanded="false">
                        Reports
                    </a>
                    <ul class="dropdown-menu reports-dropdown-menu" aria-labelledby="reportsDropdown">
                        <li>
                            <a class="dropdown-item reports-dropdown-item" style="background-color: #d0eef7; color: #123246;" asp-controller="Reports" asp-action="Roles" target="_blank" rel="noopener noreferrer">
                                <span class="reports-dropdown-title">Role Report</span>
                                <span class="reports-dropdown-description">Review system roles and ...</span>
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item reports-dropdown-item" style="background-color: #d0eef7; color: #123246;" asp-controller="Reports" asp-action="Users" target="_blank" rel="noopener noreferrer">
                                <span class="reports-dropdown-title">User Report</span>
                                <span class="reports-dropdown-description">See registered users and ...</span>
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item reports-dropdown-item" style="background-color: #d0eef7; color: #123246;" asp-controller="Reports" asp-action="Products" target="_blank" rel="noopener noreferrer">
                                <span class="reports-dropdown-title">Product Report</span>
                                <span class="reports-dropdown-description">Browse product records and ...</span>
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item reports-dropdown-item" style="background-color: #d0eef7; color: #123246;" asp-controller="Reports" asp-action="Categories" target="_blank" rel="noopener noreferrer">
                                <span class="reports-dropdown-title">Category Report</span>
                                <span class="reports-dropdown-description">View category groupings used ...</span>
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item reports-dropdown-item" style="background-color: #d0eef7; color: #123246;" asp-controller="Reports" asp-action="Contactus" target="_blank" rel="noopener noreferrer">
                                <span class="reports-dropdown-title">Contact Us Report</span>
                                <span class="reports-dropdown-description">Check submitted contact ...</span>
                            </a>
                        </li>
                    </ul>
                </li>
            </ul> 
            <!-- Topbar Right Authentication Controls --> 
            <ul class="navbar-nav align-items-center gap-2"> 
                @if (User.Identity?.IsAuthenticated == true) 
                { 
                    <li class="nav-item"> 
                        <label name=lblUserInfo class="fw-semibold me-2">Welcome, @User.Identity.Name!</label>
                    </li> 
                    <li class="nav-item"> 
                        <form class="m-0" asp-controller="Account" asp-action="Logout" method="post"> 
                            @Html.AntiForgeryToken() 
                            <button type="submit" class="btn px-3 fw-semibold" style="background-color: #d0eef7; color: #123246;">Logout</button> 
                        </form> 
                    </li> 
                    } 
                    else 
                    { 
                        <li class="nav-item"> 
                            <a class="nav-link text-white px-3" asp-controller="Account" asp-action="Register">Register</a> 
                            </li> 
                        <li class="nav-item"> 
                            <a class="nav-link text-white px-3" asp-controller="Account" asp-action="Login">Login</a> 
                        </li> 
                    } 
                    </ul> 
                </div> 
            </div> 
        </nav> 
    <!-- Main Workspace Container --> 
    <div class="d-flex flex-grow-1 align-items-stretch app-shell"> 
        <!-- Dynamic Main View Content Area --> 
        <main role="main" class="flex-grow-1 p-0 overflow-auto admin-content"> 
            <div class="admin-content-surface">
                @if (isAdmin)
                {
                    <section class="admin-blocks-panel mb-4">
                        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3 mb-4">
                            <div>
                                <p class="admin-sidebar-kicker mb-2">Control Panel</p>
                                <h1 class="h3 mb-1 text-dark">Admin Workspace</h1>
                                <p class="text-muted mb-0">Use these blocks to jump into management pages, reports, and ordering tools.</p>
                            </div>
                            <div class="text-muted small">Signed in as <strong>@User.Identity?.Name</strong></div>
                        </div>
                        <div class="admin-block-grid">
                            <a class="admin-block-card left-nav-gallery-card-users" asp-controller="User" asp-action="Index">
                                <span class="left-nav-gallery-icon" aria-hidden="true"></span>
                                <span class="admin-block-title">Users</span>
                                <span class="admin-block-copy">Manage registered accounts and profiles.</span>
                            </a>
                            <a class="admin-block-card left-nav-gallery-card-roles" asp-controller="Role" asp-action="Index">
                                <span class="left-nav-gallery-icon" aria-hidden="true"></span>
                                <span class="admin-block-title">Roles</span>
                                <span class="admin-block-copy">Maintain role setup and system info.</span>
                            </a>
                            <a class="admin-block-card left-nav-gallery-card-products" asp-controller="Product" asp-action="Index">
                                <span class="left-nav-gallery-icon" aria-hidden="true"></span>
                                <span class="admin-block-title">Products</span>
                                <span class="admin-block-copy">Update menu items, pricing, exc.</span>
                            </a>
                            <a class="admin-block-card left-nav-gallery-card-categories" asp-controller="Category" asp-action="Index">
                                <span class="left-nav-gallery-icon" aria-hidden="true"></span>
                                <span class="admin-block-title">Categories</span>
                                <span class="admin-block-copy">Organize menu groupings across the system.</span>
                            </a>
                            <a class="admin-block-card left-nav-gallery-card-menu" asp-controller="Home" asp-action="Ordering">
                                <span class="left-nav-gallery-icon" aria-hidden="true"></span>
                                <span class="admin-block-title">Our Menu</span>
                                <span class="admin-block-copy">Open ordering experience, view items.</span>
                            </a>
                            <a class="admin-block-card left-nav-gallery-card-notifications" asp-controller="Home" asp-action="Specials">
                                <span class="left-nav-gallery-icon" aria-hidden="true"></span>
                                <span class="admin-block-title">Notifications</span>
                                <span class="admin-block-copy">Open notification and specials area.</span>
                            </a>
                        </div>
                    </section>
                }
                @RenderBody()
            </div>
        </main> 
    </div> 
    <!-- Footer Area --> 
    <footer class="footer border-top mt-auto shadow-sm admin-footer" style="height: 55px;"> 
        <div class="container-fluid d-flex justify-content-between align-items-center h-100 px-4"> 
            <ul class="nav"> 
                <li class="nav-item"> 
                    <span class="nav-link text-white px-3">Created by Riaan</span> 
                </li> 
            </ul> 
        </div> 
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (() => {
            const cartStorageKey = "easy-eats-cart";
            const cartCount = document.getElementById("nav-cart-count");

            if (!cartCount) {
                return;
            }

            const readCart = () => {
                try {
                    const rawCart = localStorage.getItem(cartStorageKey);
                    const parsedCart = rawCart ? JSON.parse(rawCart) : [];
                    return Array.isArray(parsedCart) ? parsedCart : [];
                } catch {
                    return [];
                }
            };

            const syncCartSummary = () => {
                const cart = readCart();
                const totalItems = cart.reduce((sum, item) => sum + (Number(item.quantity) || 0), 0);

                cartCount.textContent = totalItems.toString();
            };

            window.addEventListener("storage", syncCartSummary);
            window.addEventListener("cart-updated", syncCartSummary);
            syncCartSummary();
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
